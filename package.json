{
	"name": "cornu-spline",
	"version": "0.2.0",
	"description": "Smooth Cornu (Euler-spiral / Spiro) interpolating splines through points — vanilla JS + React, with SVG, Canvas, text rendering, and animation.",
	"keywords": [
		"cornu",
		"euler-spiral",
		"clothoid",
		"spiro",
		"spline",
		"interpolation",
		"bezier",
		"curve",
		"svg",
		"canvas",
		"react"
	],
	"author": "QuiteQuinn",
	"license": "(MIT OR Apache-2.0)",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/QuiteQuinn/cornu-spline.git"
	},
	"homepage": "https://github.com/QuiteQuinn/cornu-spline#readme",
	"bugs": {
		"url": "https://github.com/QuiteQuinn/cornu-spline/issues"
	},
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./react": {
			"types": "./dist/react.d.ts",
			"import": "./dist/react.js",
			"require": "./dist/react.cjs"
		},
		"./text": {
			"types": "./dist/text.d.ts",
			"import": "./dist/text.js",
			"require": "./dist/text.cjs"
		}
	},
	"files": [
		"dist",
		"LICENSE-MIT",
		"LICENSE-APACHE",
		"NOTICE"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "npm run build"
	},
	"dependencies": {
		"opentype.js": "^2.0.0"
	},
	"peerDependencies": {
		"react": ">=17"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/opentype.js": "^1.3.10",
		"@types/react": "^18.3.0",
		"react": "^18.3.0",
		"tsup": "^8.3.0",
		"typescript": "^5.6.0",
		"vitest": "^2.1.0"
	}
}
